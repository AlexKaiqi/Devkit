# ============================================================
# Devkit 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================================

# --- 豆包语音 (Doubao Speech) ---
# 火山引擎控制台 → 语音技术 → 语音识别大模型 / 语音合成大模型
# 同一 APPID/TOKEN 可同时用于 STT (语音识别) 和 TTS (语音合成)
DOUBAO_APPID=
DOUBAO_TOKEN=
STT_PROXY_PORT=8787

# --- LLM (OpenAI 兼容接口) ---
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o

# --- 视觉理解 (Vision) ---
# 图片/视频理解使用视觉模型，通过同一 LLM 代理调用
# 默认 gemini-2.5-flash-nothinking，也可用 gpt-4o 等支持视觉的模型
VISION_MODEL=gemini-2.5-flash-nothinking

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_TOKEN=your-shared-secret-here
OPENCLAW_GATEWAY_PORT=18789

# --- OpenCami (Web UI) ---
OPENCAMI_PORT=3000

# --- 语音对话 (Voice Chat) ---
VOICE_CHAT_PORT=3001
# TTS 音色（豆包 TTS）：BV033_streaming(知悦/知性), BV034_streaming(知意/温柔), BV143_streaming(温柔大姐姐)...
TTS_VOICE=BV033_streaming
# TTS 语速：1.0 正常，1.25 稍快，1.5 快速
TTS_SPEED=1.25

# --- SearXNG 搜索引擎 ---
# 本地 Docker 部署，无需 API Key
SEARXNG_URL=http://localhost:8080

# --- Home Assistant ---
# 在 HA 个人资料页面创建长期访问令牌
# HASS_SERVER=http://homeassistant.local:8123
# HASS_TOKEN=

# --- 邮件 (himalaya) ---
# himalaya 使用自身配置文件 ~/.config/himalaya/config.toml
# 参考: https://pimalaya.org/himalaya/cli/latest/configuration/
# IMAP_HOST=
# IMAP_USER=
# SMTP_HOST=

# --- 日历 (vdirsyncer) ---
# vdirsyncer 使用自身配置文件 ~/.config/vdirsyncer/config
# 参考: https://vdirsyncer.pimutils.org/en/stable/config.html

# --- Telegram Bot (主动通知) ---
# 1. Telegram 搜索 @BotFather → /newbot → 获取 Token
# 2. 给 Bot 发一条消息，然后访问:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    从返回 JSON 中找 result[0].message.chat.id
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Peekaboo (桌面 GUI 自动化) ---
# 需要在系统设置中授予屏幕录制权限
# AI 视觉分析复用 LLM_API_KEY + VISION_MODEL
PEEKABOO_AI_PROVIDERS=openai/gpt-4o
