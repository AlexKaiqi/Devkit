# ============================================================
# Devkit 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================================

# ┌─────────────────────────────────────────────┐
# │  必填 — 不填则项目无法运行                    │
# └─────────────────────────────────────────────┘

# --- 豆包语音 (Doubao Speech) ---
# 火山引擎控制台 → 语音技术 → 语音识别大模型 / 语音合成大模型
# 同一 APPID/TOKEN 可同时用于 STT (语音识别) 和 TTS (语音合成)
# 获取: https://console.volcengine.com/speech/service/8
DOUBAO_APPID=
DOUBAO_TOKEN=

# --- LLM (OpenAI 兼容接口) ---
# 用于 Agent 推理和视觉理解，支持任何 OpenAI 兼容代理
# 推荐: yinli.one、openrouter.ai 等
LLM_API_KEY=
LLM_BASE_URL=

# ┌─────────────────────────────────────────────┐
# │  可选 — Agent 配置                           │
# └─────────────────────────────────────────────┘

# Agent 推理模型（默认 gemini-3.1-pro-preview）
# AGENT_MODEL=gemini-3.1-pro-preview

# Agent 人设目录（默认 persona/）
# WORKSPACE_DIR=persona

# 视觉理解模型（图片/视频分析，默认 gemini-2.5-flash-nothinking）
# VISION_MODEL=gemini-2.5-flash-nothinking

# ┌─────────────────────────────────────────────┐
# │  可选 — 端口（默认值即可用，一般不需要修改）    │
# └─────────────────────────────────────────────┘

STT_PROXY_PORT=8787
VOICE_CHAT_PORT=3001

# ┌─────────────────────────────────────────────┐
# │  可选 — 语音合成                              │
# └─────────────────────────────────────────────┘

# 默认 TTS 音色（豆包语音合成大模型）
# 风铃右上角可实时切换 25+ 大模型音色
TTS_VOICE=zh_female_tianmeixiaoyuan_moon_bigtts
# TTS 语速：1.0 正常，1.25 稍快，1.5 快速
TTS_SPEED=1.25

# ┌─────────────────────────────────────────────┐
# │  可选 — 扩展功能（按需取消注释并填入）         │
# └─────────────────────────────────────────────┘

# --- Telegram Bot ---
# 1. Telegram 搜索 @BotFather → /newbot → 获取 Token
# 2. 给 Bot 发一条消息，然后访问:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    从返回 JSON 中找 result[0].message.chat.id
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- OpenRouter (备用 LLM 代理) ---
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Home Assistant ---
# 在 HA 个人资料页面创建长期访问令牌
# HASS_SERVER=http://homeassistant.local:8123
# HASS_TOKEN=

# --- SearXNG 搜索引擎 ---
# 本地 Docker 部署，无需 API Key，start.sh 自动管理
SEARXNG_URL=http://localhost:8080

# --- Peekaboo (桌面 GUI 自动化) ---
# 需要在系统设置中授予屏幕录制权限
# PEEKABOO_AI_PROVIDERS=openai/gpt-4o
