# ============================================================
# Devkit 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================================

# ┌─────────────────────────────────────────────┐
# │  必填 — 不填则项目无法运行                    │
# └─────────────────────────────────────────────┘

# --- 豆包语音 (Doubao Speech) ---
# 火山引擎控制台 → 语音技术 → 语音识别大模型 / 语音合成大模型
# 同一 APPID/TOKEN 可同时用于 STT (语音识别) 和 TTS (语音合成)
# 获取: https://console.volcengine.com/speech/service/8
DOUBAO_APPID=
DOUBAO_TOKEN=

# --- OpenClaw Gateway ---
# 风铃/Telegram 连接 Gateway 的共享密钥
# setup.sh 首次运行会自动生成随机值；也可手动设置
# 注意：此值需与 ~/.openclaw/openclaw.json 中 gateway.token 一致
OPENCLAW_GATEWAY_TOKEN=

# ┌─────────────────────────────────────────────┐
# │  LLM 配置说明                                │
# │  LLM 由 OpenClaw Gateway 统一管理，不在此配置  │
# │  首次运行: openclaw onboard 交互式选择 provider │
# │  修改配置: 编辑 ~/.openclaw/openclaw.json      │
# └─────────────────────────────────────────────┘

# ┌─────────────────────────────────────────────┐
# │  可选 — 端口（默认值即可用，一般不需要修改）    │
# └─────────────────────────────────────────────┘

STT_PROXY_PORT=8787
OPENCLAW_GATEWAY_PORT=18789
OPENCAMI_PORT=3000
VOICE_CHAT_PORT=3001

# ┌─────────────────────────────────────────────┐
# │  可选 — 语音合成                              │
# └─────────────────────────────────────────────┘

# 默认 TTS 音色（豆包语音合成大模型）
# 风铃右上角可实时切换 25+ 大模型音色
TTS_VOICE=zh_female_tianmeixiaoyuan_moon_bigtts
# TTS 语速：1.0 正常，1.25 稍快，1.5 快速
TTS_SPEED=1.25

# ┌─────────────────────────────────────────────┐
# │  可选 — 扩展功能（按需取消注释并填入）         │
# └─────────────────────────────────────────────┘

# --- Telegram Bot ---
# 1. Telegram 搜索 @BotFather → /newbot → 获取 Token
# 2. 给 Bot 发一条消息，然后访问:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    从返回 JSON 中找 result[0].message.chat.id
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Home Assistant ---
# 在 HA 个人资料页面创建长期访问令牌
# HASS_SERVER=http://homeassistant.local:8123
# HASS_TOKEN=

# --- SearXNG 搜索引擎 ---
# 本地 Docker 部署，无需 API Key，start.sh 自动管理
SEARXNG_URL=http://localhost:8080

# --- 邮件 (himalaya) ---
# himalaya 使用自身配置文件 ~/.config/himalaya/config.toml
# 参考: https://pimalaya.org/himalaya/cli/latest/configuration/

# --- 日历 (vdirsyncer) ---
# vdirsyncer 使用自身配置文件 ~/.config/vdirsyncer/config
# 参考: https://vdirsyncer.pimutils.org/en/stable/config.html

# --- Peekaboo (桌面 GUI 自动化) ---
# 需要在系统设置中授予屏幕录制权限
# AI 视觉分析由 Gateway LLM 处理
# PEEKABOO_AI_PROVIDERS=openai/gpt-4o
