# ============================================================
# Devkit 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================================

# ┌─────────────────────────────────────────────┐
# │  必填 — 不填则项目无法运行                    │
# └─────────────────────────────────────────────┘

# --- 豆包语音 (Doubao Speech) ---
DOUBAO_APPID=
DOUBAO_TOKEN=

# --- LLM (OpenAI 兼容接口) ---
LLM_API_KEY=
LLM_BASE_URL=

# ┌─────────────────────────────────────────────┐
# │  可选 — Agent 配置                           │
# └─────────────────────────────────────────────┘

# AGENT_MODEL=gemini-3.1-pro-preview

# Agent persona 目录（默认 implementation/assets/persona/）
# WORKSPACE_DIR=implementation/assets/persona

# VISION_MODEL=gemini-2.5-flash-nothinking

# ┌─────────────────────────────────────────────┐
# │  可选 — 端口                                  │
# └─────────────────────────────────────────────┘

STT_PROXY_PORT=8787
VOICE_CHAT_PORT=3001
TIMER_API_PORT=8789

# ┌─────────────────────────────────────────────┐
# │  可选 — 语音合成                              │
# └─────────────────────────────────────────────┘

TTS_VOICE=zh_female_tianmeixiaoyuan_moon_bigtts
TTS_SPEED=1.25

# ┌─────────────────────────────────────────────┐
# │  可选 — 扩展功能                              │
# └─────────────────────────────────────────────┘

# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# HASS_SERVER=http://homeassistant.local:8123
# HASS_TOKEN=

SEARXNG_URL=http://localhost:8080
