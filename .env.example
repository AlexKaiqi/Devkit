# ============================================================
# Devkit 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================================

# --- 豆包语音 (Doubao Speech) ---
# 火山引擎控制台 → 语音技术 → 语音识别大模型 / 语音合成大模型
# 同一 APPID/TOKEN 可同时用于 STT (语音识别) 和 TTS (语音合成)
DOUBAO_APPID=
DOUBAO_TOKEN=
STT_PROXY_PORT=8787

# --- LLM (OpenAI 兼容接口) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# --- 视觉理解 (Vision) ---
# 图片/视频理解使用 Gemini，通过同一 LLM 代理调用
# 默认 gemini-2.5-flash-nothinking，也可用 gemini-2.5-pro 等
VISION_MODEL=gemini-2.5-flash-nothinking

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789

# --- OpenCami (Web UI) ---
OPENCAMI_PORT=3000
